# syntax=docker/dockerfile:1.7

FROM oven/bun:1.2.2 AS builder

WORKDIR /app/web

COPY web/package.json web/bun.lock ./
RUN bun install --frozen-lockfile

COPY web/ ./

ARG PUBLIC_LS_API_BASE_URL=http://127.0.0.1:8096
ENV PUBLIC_LS_API_BASE_URL=${PUBLIC_LS_API_BASE_URL}
ARG PUBLIC_LS_ENABLE_MOCK=false
ENV PUBLIC_LS_ENABLE_MOCK=${PUBLIC_LS_ENABLE_MOCK}

RUN bun run build

FROM nginx:1.27-bookworm AS runtime

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates tzdata \
    && rm -rf /var/lib/apt/lists/*

# Remove default nginx config
RUN rm -f /etc/nginx/conf.d/default.conf

COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/web/dist /usr/share/nginx/html
COPY docker/web-entrypoint.sh /usr/local/bin/lumenstream-web-entrypoint.sh
COPY docker/write-web-runtime-config.sh /usr/local/bin/lumenstream-write-web-runtime-config.sh

RUN chmod +x /usr/local/bin/lumenstream-web-entrypoint.sh \
    && chmod +x /usr/local/bin/lumenstream-write-web-runtime-config.sh

EXPOSE 4321

ENTRYPOINT ["/usr/local/bin/lumenstream-web-entrypoint.sh"]
