# LumenStream backend API base URL (cross-domain deployment)
PUBLIC_LS_API_BASE_URL=http://127.0.0.1:8096
PUBLIC_APP_TITLE=LumenStream Web

# Optional override for mock feature.
# If unset: dev=true, build/deploy=false.
# PUBLIC_LS_ENABLE_MOCK=false

# Optional: force mock mode for all pages (true/false).
# Works only when mock feature is enabled.
# PUBLIC_LS_MOCK_MODE=false
