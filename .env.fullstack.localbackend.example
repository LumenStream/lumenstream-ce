# Required on first boot
LS_BOOTSTRAP_ADMIN_USER=replace-with-admin-user
LS_BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-password

# Required for token verification between LumenStream and lumenlocalbackend-rs
LS_LUMENBACKEND_STREAM_SIGNING_KEY=replace-with-a-long-random-secret

# Local media mount on host and inside containers
LOCAL_MEDIA_MOUNT_SOURCE=/path/to/your/media
LOCAL_MEDIA_MOUNT_TARGET=/media

# Build context for the open-source local backend repo
LUMENLOCALBACKEND_BUILD_CONTEXT=../lumenlocalbackend-rs

# Optional overrides
MEILI_MASTER_KEY=ls_meili_default_key
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=lumenstream
LS_DATABASE_URL=postgres://postgres:postgres@postgres:5432/lumenstream
LS_DATABASE_MAX_CONNECTIONS=20
LS_LUMENBACKEND_ENABLED=true
LS_LUMENBACKEND_NODES=http://stream-gateway:8096
LS_LOCAL_STREAM_ROUTE=v1/streams/local
LS_SCAN_LOCAL_MEDIA_EXTS=mp4,mkv,flv,avi,mov,m4v,ts,m2ts,wmv,iso
LS_LUMENBACKEND_STREAM_TOKEN_TTL_SECONDS=86400

# Optional web runtime API base URL override (for reverse proxy/domain deployment)
# LS_API_BASE_URL=https://media.example.com
