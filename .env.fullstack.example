# Compose image override (optional)
# LS_FULLSTACK_IMAGE=ghcr.io/lumenstream/lumenstream-ce-fullstack:latest

# Required on first boot (when DB has no admin user)
LS_BOOTSTRAP_ADMIN_USER=replace-with-admin-user
LS_BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-password

# Meilisearch master key (required for production mode)
MEILI_MASTER_KEY=ls_meili_default_key

# Optional overrides
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=lumenstream
LS_DATABASE_URL=postgres://postgres:postgres@postgres:5432/lumenstream
LS_DATABASE_MAX_CONNECTIONS=20

# Optional web runtime API base URL override (for reverse proxy/domain deployment)
# LS_API_BASE_URL=https://media.example.com

# For local-file + localbackend bundled deployment, use:
#   cp .env.fullstack.localbackend.example .env
#   docker compose -f docker-compose.fullstack.localbackend.yml up -d --build
